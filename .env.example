# ============================================================
# Polymarket Trading System — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# --- Polymarket API Credentials ---
# Your EOA wallet private key (hex, no 0x prefix needed)
POLY_PRIVATE_KEY=your_private_key_here
# L2 API credentials (derived from wallet via createorderiveapicreds)
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# --- Polymarket API Endpoints ---
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Trading Parameters ---
# Start SMALL — audit recommends $500 max for first deployment
MAX_CAPITAL_USD=500.0
# 3% max per position (audit hard cap for resolution timing)
MAX_POSITION_PCT=0.03
# 8% daily drawdown limit (kill switch trigger)
DAILY_DRAWDOWN_LIMIT=0.08
# Minimum 6¢ gross edge before oracle risk buffer (audit requirement)
MIN_EDGE_CENTS=6.0
# Oracle risk buffer: 0.5% for category-A (sports/govt data), 2% others
ORACLE_RISK_BUFFER_A=0.005
ORACLE_RISK_BUFFER_DEFAULT=0.02
# Fractional Kelly multiplier (25% of full Kelly)
KELLY_FRACTION=0.25

# --- Safety ---
# ALWAYS keep True until you've validated sim fills match live fills
SIM_MODE=true

# --- Infrastructure ---
DATABASE_URL=sqlite+aiosqlite:///./trading.db
LOG_LEVEL=INFO
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# --- Alerts (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
